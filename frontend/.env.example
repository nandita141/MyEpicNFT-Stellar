# ─────────────────────────────────────────────────────────────────────────────
# MyEpicNFT-Stellar — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# The Soroban contract ID (CDQ... format)
VITE_CONTRACT_ID=CDQ4LCGKICDNAQKRFGPCTDVDNWUU7JIVXGWKGSPA3A5A44Q45PCB7PD4

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Stellar RPC URL
VITE_RPC_URL=https://soroban-testnet.stellar.org:443

# Network label: testnet | mainnet
VITE_NETWORK=testnet

# Stellar network passphrase
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Vercel deployment URL (for CORS / meta tags)
VITE_APP_URL=https://my-epic-nft-stellar-frontend-48b7.vercel.app
